{
  "name": "chat-analyze",
  "version": "1.0.0",
  "description": "Gemini Chat Analyze & Evolver",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "ui"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @chat-analyze/server",
    "dev:ui": "npm run dev -w ui",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3"
  }
}
